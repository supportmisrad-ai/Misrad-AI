# Example environment variables. Copy the relevant keys into .env.local (recommended) or your hosting provider env settings.

# ─── Clerk Authentication ──────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Webhook secret — from Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=
# Sign-in / sign-up redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/me
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/me

# ─── Database (Prisma) ─────────────────────────────────────────────
# Required for all server-side pages/API routes that use Prisma.
# For Prisma Accelerate: use prisma://accelerate.prisma-data.net/?api_key=YOUR_KEY
# For direct connection: use postgresql://user:pass@host:port/db
DATABASE_URL=
# Required: direct connection to the database (bypasses pooler/Accelerate).
# Used by Prisma Migrate, interactive transactions, and CLI tooling.
# IMPORTANT: In production, DIRECT_URL is used by default to avoid Supabase RLS
# "Tenant or user not found" errors (RLS requires JWT claims that Prisma doesn't send through pooler).
# Example: postgresql://postgres.xxx:password@db.xxx.supabase.co:5432/postgres
DIRECT_URL=
# Optional: used by Prisma migration tooling
SHADOW_DATABASE_URL=
# Optional: force pooler usage in production (default: false in prod, uses DIRECT_URL)
# Set to 'false' to use DIRECT_URL, 'true' to force pooler
# MISRAD_PRISMA_PREFER_DIRECT=true

# Sentry DSN (server-side)
SENTRY_DSN=

# Sentry DSN for browser/client (optional - enables reporting of client-side errors)
NEXT_PUBLIC_SENTRY_DSN=

# Optional: enable/disable Sentry in non-prod
SENTRY_ENABLED=true

# Web Push (PWA) - VAPID keys
# Generate once and put in .env.local / hosting env vars.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# Optional (defaults to support@misrad-ai.com)
WEB_PUSH_VAPID_SUBJECT=mailto:support@misrad-ai.com

# Encryption key for API keys at rest (ai_provider_keys, integration credentials).
# REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Upstash Redis (used for rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Global rate limiting (optional, defaults shown)
# MISRAD_GLOBAL_RATE_LIMIT=200
# MISRAD_GLOBAL_RATE_WINDOW_MS=60000

# Zoom Integration (OAuth App)
# Get these from https://marketplace.zoom.us/develop/create
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Optional (defaults to /api/integrations/zoom/callback)
ZOOM_REDIRECT_URI=

# Cron Job Authentication
# REQUIRED for cron endpoints (e.g., /api/cron/check-trial-expiry)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRON_SECRET=

# Morning (Green Invoice) - App-Level Billing
# REQUIRED for billing organizations (Level 1 billing)
# Get API key from Morning account settings (requires Best plan or higher)
MORNING_APP_API_KEY=
# Webhook secret for verifying Morning webhook requests
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Configure this secret in Morning webhook settings
MORNING_WEBHOOK_SECRET=

# ─── Email System (Resend) ─────────────────────────────────────────
# Primary Resend API key (transactional emails: auth, billing, support, invitations)
RESEND_API_KEY=
# Optional: Separate Resend API key for marketing emails (protects transactional reputation)
RESEND_MARKETING_API_KEY=
# Default "from" address (fallback if per-category addresses not verified yet)
RESEND_FROM_EMAIL=onboarding@resend.dev
# Optional: override all recipients for testing (sends ALL emails to this address)
RESEND_TEST_TO=

# Per-category sender overrides (use while migrating to dedicated addresses)
# EMAIL_FROM_TRANSACTIONAL=no-reply@misrad-ai.com
# EMAIL_FROM_ONBOARDING=hello@misrad-ai.com
# EMAIL_FROM_TEAM=team@misrad-ai.com
# EMAIL_FROM_BILLING=billing@misrad-ai.com
# EMAIL_FROM_SUPPORT=support@misrad-ai.com
# EMAIL_FROM_SYSTEM=notifications@misrad-ai.com
# EMAIL_FROM_MARKETING=news@misrad-ai.com
# EMAIL_FROM_ORGANIZATION=notifications@misrad-ai.com

# Unsubscribe token secret (for marketing email unsubscribe links)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_UNSUBSCRIBE_SECRET=

# Founder personal email settings
MISRAD_FOUNDER_NAME=איציק
MISRAD_FOUNDER_PHONE=
MISRAD_SUPPORT_EMAIL=support@misrad-ai.com
MISRAD_SUPPORT_FROM_EMAIL=support@misrad-ai.com
# Admin notification email (receives alerts for new signups & payments)
# Supports comma-separated list for multiple recipients
MISRAD_ADMIN_NOTIFICATION_EMAIL=

# Google Business review URL (for customer rating system)
# Get from Google Business Profile → Share review link
MISRAD_GOOGLE_REVIEW_URL=
NEXT_PUBLIC_MISRAD_GOOGLE_REVIEW_URL=

# WhatsApp support link (used in follow-up emails)
MISRAD_SUPPORT_WHATSAPP_URL=

# ─── AI Providers ─────────────────────────────────────────────────
# At least GEMINI_API_KEY is REQUIRED for AI features (transcription, insights, etc.)
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional: Anthropic/Claude for advanced reasoning (call analysis, insights)
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional: Deepgram for dedicated transcription (fallback to Gemini if missing)
# Get from https://console.deepgram.com
DEEPGRAM_API_KEY=
# Optional: OpenAI for embeddings/vision
OPENAI_API_KEY=
# Optional: Groq for fast inference (objection handling)
GROQ_API_KEY=

# ─── Messaging Channels (Communication Center) ──────────────────
# These are OPTIONAL — organizations can also configure per-tenant credentials
# via the admin settings UI (BYOC model stored in system_settings).

# WhatsApp Business Cloud API (Meta)
# Get from: https://developers.facebook.com/apps → WhatsApp → API Setup
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_BUSINESS_ACCOUNT_ID=

# SMS (Twilio)
# Get from: https://console.twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ─── Social Media OAuth (Direct Publishing) ──────────────────────
# Facebook OAuth - for Facebook Pages & Instagram Business
# Get from: https://developers.facebook.com/apps → Settings → Basic
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# LinkedIn OAuth - for LinkedIn publishing
# Get from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# OAuth State Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
OAUTH_STATE_SECRET=

# Cron Job Secret (for scheduled publishing & token refresh)
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ─── WhatsApp Bot (WAAM-It Blaster) ──────────────────────────────
# Optional secret to validate incoming webhooks from Blaster
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BLASTER_WEBHOOK_SECRET=

# ─── Voicenter Telephony Integration ─────────────────────────────
# Optional secret to validate incoming webhooks from Voicenter
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used to verify webhook signatures in production
VOICENTER_WEBHOOK_SECRET=

# ─── Coupon System Security ──────────────────────────────────────
# REQUIRED: Secret pepper for hashing coupon codes (prevents brute-force)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this, coupon validation will fail in production with "Missing COUPON_CODE_PEPPER"
COUPON_CODE_PEPPER=
