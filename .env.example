# Example environment variables. Copy the relevant keys into .env.local (recommended) or your hosting provider env settings.

# Sentry DSN (server-side)
SENTRY_DSN=

# Sentry DSN for browser/client (optional - enables reporting of client-side errors)
NEXT_PUBLIC_SENTRY_DSN=

# Optional: enable/disable Sentry in non-prod
SENTRY_ENABLED=true
