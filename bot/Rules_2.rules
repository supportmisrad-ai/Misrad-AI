[{"sendByDate":false,"Rule":"1##התחל##הי##היי##שלום##start##בוקר טוב##ערב טוב##מה נשמע","response":"header:`*MISRAD AI* 🤖`\\\ndescription:`היי! אני הבוט של MISRAD AI.\n\nמערכת ה-AI שמנהלת את הארגון שלך — ניהול צוות, מכירות, שיווק, לקוחות ותפעול, הכל ממקום אחד.\n\nאיך אפשר לעזור?`\\\nfooter:`הקלד ״תפריט״ בכל שלב לחזרה לכאן`\\\nbuttonText:`תפריט ראשי 📌`\\\nsections:<\n(list)\ntitle:`גלה את MISRAD AI`\\\nrows:<\n(item)\ntitle:`גלה את MISRAD AI 🚀`\\\ndescription:``\n(/item)\n(item)\ntitle:`חבילות ומחירים 💰`\\\ndescription:``\n(/item)\n(item)\ntitle:`התנסות חינם 7 ימים 🎁`\\\ndescription:``\n(/item)\n>\n(/list)\n(list)\ntitle:`עוד אפשרויות`\\\nrows:<\n(item)\ntitle:`קביעת הדגמה אישית 📅`\\\ndescription:``\n(/item)\n(item)\ntitle:`לאזור האישי שלי 🔑`\\\ndescription:`כבר לקוח? היכנס כאן`\n(/item)\n(item)\ntitle:`תמיכה וסיוע 🧑‍💻`\\\ndescription:``\n(/item)\n>\n(/list)","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":false,"image_caption":false,"follow_index":[],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-22T18:06:48.138Z","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"f7fd2ff5-ead4-4859-b00e-048b60f4d1be","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"2##תפריט##חזרה##חזרה לתפריט ראשי 📌","response":"header:`*MISRAD AI* 🤖`\\\ndescription:`חזרת לתפריט הראשי. איך אפשר לעזור?`\\\nfooter:``\\\nbuttonText:`תפריט ראשי 📌`\\\nsections:<\n(list)\ntitle:`גלה את MISRAD AI`\\\nrows:<\n(item)\ntitle:`גלה את MISRAD 