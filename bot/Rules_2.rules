tem)\n>\n(/list)\n\n","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":false,"image_caption":false,"follow_index":[38],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-23T00:00:00","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"d0dc65ec-e37a-4992-b56c-f6ff5483ec18","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"52##מה ההבדל בין MISRAD AI ל-CRM רגיל?","response":"*ההבדל? AI שעובד בשבילך.* 🤖\n\nCRM רגיל = כלי שאתה מזין אליו נתונים.\nMISRAD AI = מערכת שמנתחת את הנתונים ואומרת לך *מה לעשות*.\n\n*דוגמאות:*\n🔹 ״הליד הזה עומד לברוח — התקשר היום״\n🔹 ״הפרויקט הזה חורג מתקציב ב-15%״\n🔹 ״הזמן הטוב ביותר לפרסם: רביעי 11:00״\n\nבמקום לחפש מחט בערימת שחת — המערכת מביאה לך את המחט. 🎯\n\nעוד שאלה? הקלד ״שאלות נפוצות״.","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":true,"image_caption":false,"follow_index":[39],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-23T00:00:00","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"26320ad9-66a7-44dc-ba3a-4548f9fabe70","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"53##האם הנתונים שלי מאובטחים?","response":"*אבטחת מידע ברמה הגבוהה ביותר.* 🔒\n\n🔐 הצפנת SSL/TLS מקצה לקצה\n☁️ שרתי Supabase (AWS) — תקן SOC2\n🔑 הפרדת נתונים מלאה בין ארגונים (Tenant Isolation)\n📋 עמידה בתקנות GDPR\n🚫 אנחנו לעולם לא מוכרים או משתפים את הנתונים שלך\n\nהנתונים שלך = שלך. נקודה.","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":true,"image_caption":false,"follow_index":[39],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-23T00:00:00","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"92f1c11a-9c2c-41e7-adeb-d7abc1d7443c","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"54##אפשר לבטל בכל זמן?","response":"*כן, אפשר לבטל בכל רגע.* ✅\n\n🔹 ביטול בלחיצת כפתור מההגדרות\n🔹 ללא דמי ביטול, ללא התחייבות\n🔹 הנתונים שלך נשמרים 30 יום אחרי ביטול\n🔹 אפשר לחזור בכל עת\n\nאנחנו רוצים שתישאר כי המערכת עובדת — לא כי אתה כלוא.","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":true,"image_caption":false,"follow_index":[39],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-23T00:00:00","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"1952419b-11cf-471d-8bcd-388fe6fe182d","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"55##איך עובד ה-AI במערכת?","response":"*ה-AI ב-MISRAD AI הוא לא גימיק — הוא הבסיס.* 🧠\n\nה-AI מנתח את הנתונים שלך ברקע ומספק:\n\n🎯 *חיזויים* — סיכויי סגירת עסקאות, סיכון נטישת לקוחות\n💡 *המלצות* — מה לעשות, מתי, ולמי\n📊 *תובנות* — מגמות, צווארי בקבוק, הזדמנויות\n⚡ *אוטומציה* — תזכורות, משימות, התראות\n\nככל שמשתמשים יותר — ה-AI לומד ומשתפר. 📈","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":true,"image_caption":false,"follow_index":[39],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-23T00:00:00","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"86f8784e-5bbb-49db-8a80-9f522e731574","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"56##מדריכים וסרטוני הדרכה 📹","response":"*מדריכים וסרטוני הדרכה* 📹\n\nכל המדריכים זמינים באזור האישי שלך:\n🌐 *misrad-ai.com/me*\n\nכרגע עדיין לא לקוח? הנה כמה לינקים שימושיים:\n📖 מדריך התחלה מהירה — בקרוב\n🎬 סרטון דמו — בקרוב\n\nלשאלות נוספות הקלד ״תמיכה״.","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message