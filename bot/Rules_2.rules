BUSINESS}\n⏰ {DEMO_TIME}\n\nנציג שלנו ייצור איתך קשר תוך 24 שעות לאישור הזמן המדויק.\n\nבינתיים, רוצה להכיר את המערכת?\nהקלד ״תפריט״ לחזרה.","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":true,"image_caption":false,"follow_index":[35],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-23T00:00:00","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":true,"Webhook":"https://hook.eu1.make.com/REPLACE_DEMO_WEBHOOK","RuleId":"6f52ed73-5d01-4949-a20b-f77cf22b423d","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":"DEMO_TIME"}},{"sendByDate":false,"Rule":"----------------------------------------------------------","response":" ","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":false,"image_caption":false,"follow_index":[],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-23T00:00:00","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"ee8130ff-7f9a-4d62-a2b7-4fa97b905ccc","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":fal