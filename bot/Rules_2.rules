tem)\n>\n(/list)\n\n","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":false,"image_caption":false,"follow_index":[38],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-22T19:45:40","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"609c690d-9799-41d1-9f9a-46b74cdf9f99","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"52##מה ההבדל בין MISRAD AI ל-CRM רגיל?","response":"*ההבדל? AI שעובד בשבילך.* 🤖\n\nCRM רגיל = כלי שאתה מזין אליו נתונים.\nMISRAD AI = מערכת שמנתחת את הנתונים ואומרת לך *מה לעשות*.\n\n*דוגמאות:*\n🔹 ״הליד הזה עומד לברוח — התקשר היום״\n🔹 ״הפרויקט הזה חורג מתקציב ב-15%״\n🔹 ״הזמן הטוב ביותר לפרסם: רביעי 11:00״\n\nבמקום לחפש מחט בערימת שחת — המערכת מביאה לך את המחט. 🎯\n\nעוד שאלה? הקלד ״שאלות נפוצות״.","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":true,"image_caption":false,"follow_index":[39],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-22T19:45:40","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"a6a8e76c-fe1f-45cf-a6f5-8c460e1a3090","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"53##האם הנתונים שלי מאובטחים?","response":"*אבטחת מידע ברמה הגבוהה ביותר.* 🔒\n\n🔐 הצפנת SSL/TLS מקצה לקצה\n☁️ שרתי Supabase (AWS) — תקן SOC2\n🔑 הפרדת נתונים מלאה בין ארגונים (Tenant Isolation)\n📋 עמידה בתקנות GDPR\n🚫 אנחנו לעולם לא מוכרים או משתפים את הנתונים שלך\n\nהנתונים שלך = שלך. נקודה.","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":true,"image_caption":false,"follow_index":[39],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-22T19:45:40","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"142c3e05-6f7e-40bb-9f31-42532f32a7bb","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"54##אפשר לבטל בכל זמן?","response":"*כן, אפשר לבטל בכל רגע.* ✅\n\n🔹 ביטול בלחיצת כפתור מההגדרות\n🔹 ללא דמי ביטול, ללא התחייבות\n🔹 הנתונים שלך נשמרים 30 יום אחרי ביטול\n🔹 אפשר לחזור בכל עת\n\nאנחנו רוצים שתישאר כי המערכת עובדת — לא כי אתה כלוא.","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":true,"image_caption":false,"follow_index":[39],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-22T19:45:40","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"5ded218c-3ab7-403f-b4c6-699f93bedddd","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"55##איך עובד ה-AI במערכת?","response":"*ה-AI ב-MISRAD AI הוא לא גימיק — הוא הבסיס.* 🧠\n\nה-AI מנתח את הנתונים שלך ברקע ומספק:\n\n🎯 *חיזויים* — סיכויי סגירת עסקאות, סיכון נטישת לקוחות\n💡 *המלצות* — מה לעשות, מתי, ולמי\n📊 *תובנות* — מגמות, צווארי בקבוק, הזדמנויות\n⚡ *אוטומציה* — תזכורות, משימות, התראות\n\nככל שמשתמשים יותר — ה-AI לומד ומשתפר. 📈","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":true,"image_caption":false,"follow_index":[39],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-22T19:45:40","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"067c2d7c-a40c-4b20-9f75-4d912a80ab7f","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"56##מדריכים וסרטוני הדרכה 📹","response":"*מדריכים וסרטוני הדרכה* 📹\n\nכל המדריכים זמינים באזור האישי שלך:\n🌐 *misrad-ai.com/me*\n\nכרגע עדיין לא לקוח? הנה כמה לינקים שימושיים:\n📖 מדריך התחלה מהירה — בקרוב\n🎬 סרטון דמו — בקרוב\n\nלשאלות נוספות הקלד ״תמיכה״.","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message