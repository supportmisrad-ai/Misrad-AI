st)","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":false,"image_caption":false,"follow_index":[38],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-22T18:06:48.148Z","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"939b09c8-8796-468f-9e58-7991bfe52a97","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterOlderMessages":false,"ResetScore":false,"AddToScore":0,"AnswerIfScore":false,"AnswerScoreMin":0,"AnswerScoreMax":0,"Variable":null}},{"sendByDate":false,"Rule":"52##מה ההבדל בין MISRAD AI ל-CRM רגיל?","response":"*ההבדל? AI שעובד בשבילך.* 🤖\n\nCRM רגיל = כלי שאתה מזין אליו נתונים.\nMISRAD AI = מערכת שמנתחת את הנתונים ואומרת לך *מה לעשות*.\n\n*דוגמאות:*\n🔹 ״הליד הזה עומד לברוח — התקשר היום״\n🔹 ״הפרויקט הזה חורג מתקציב ב-15%״\n🔹 ״הזמן הטוב ביותר לפרסם: רביעי 11:00״\n\nבמקום לחפש מחט בערימת שחת — המערכת מביאה לך את המחט. 🎯\n\nעוד שאלה? הקלד ״שאלות נפוצות״.","Delay":0,"DelayType":0,"notification":false,"not_numbers":[],"not_message":"","files":[],"contains":true,"image_caption":false,"follow_index":[39],"var_index":-1,"followAfterDelay":-1,"followAfterDelayType":-1,"Cooldown":0,"_Date":"2026-02-22T18:06:48.148Z","Color":"White","CustomColor":false,"IsGif":false,"extra":{"_IsSticker":false,"_Isrecording":false,"AutoLinkPreview":false,"FilesBeforeText":false,"ThirdPartyPreMessage":true,"Active":true,"SendWebhook":false,"Webhook":"","RuleId":"1188f090-afc2-42fa-8c9a-74d571f0d8cc","Campaign":null,"CampaignOption":0,"CooldownAsCounter":false,"Quote":false,"AsPtv":false,"Anchor":false,"ResetVarsAfterWebhook":false,"DontModifyLastRule":false,"AICooldown":0,"UnregisterO