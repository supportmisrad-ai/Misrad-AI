{
  "name": "misrad-ai",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "db:protect-orgs": "node scripts/protect-organizations.js",
    "db:protect-scripts": "node scripts/protect-the-protector.js",
    "db:check:protection": "node scripts/monitor-protected-files.js",
    "security:block-dangerous": "node scripts/command-interceptor.js install",
    "preinstall": "node scripts/command-interceptor.js check",
    "db:named-backup": "node scripts/named-backup.js",
    "db:safe": "node scripts/force-backup-wrapper.js",
    "dev": "next dev -p 4000 --webpack",
    "dev:turbo": "next dev -p 5000",
    "postinstall": "node scripts/prisma-generate-safe.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:no-postgrest": "node scripts/check-no-postgrest.cjs",
    "validate:ci": "node scripts/validate-ci-config.js",
    "security:scan-prisma-take": "node scripts/security/scan-prisma-take-limits.js",
    "audit:prisma:migrations:table-refs": "node scripts/audit-prisma-migrations-table-refs.cjs",
    "build": "npm run security:scan-api-guards && npm run security:scan-actions-guards && npm run security:scan-layer-boundaries && npm run security:assert-no-prod-bypass && npm run security:no-new-prisma-any && npm run check:no-postgrest && npm run prisma:migrate:deploy:ci && npm run prisma:migrations:check && npm run prisma:migrations:sync && npm run security:rls:coverage && npm run prisma:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "security:scan-api-guards": "node scripts/security/scan-api-guards.js",
    "security:scan-actions-guards": "node scripts/security/scan-actions-guards.js",
    "security:scan-layer-boundaries": "node scripts/security/scan-layer-boundaries.js",
    "security:assert-no-prod-bypass": "node scripts/security/assert-no-prod-bypass.js",
    "security:no-new-prisma-any": "node scripts/security/check-no-new-prisma-as-any.cjs",
    "security:rls:coverage": "node scripts/db-check-rls-coverage.cjs",
    "prisma:migrate:deploy:ci": "node scripts/prisma-migrate-deploy-ci.cjs",
    "prisma:migrations:check": "node scripts/db-check-prisma-migrations.cjs",
    "prisma:migrations:sync": "node scripts/db-check-prisma-migration-sync.cjs",
    "e2e:auth": "node scripts/e2e-auth.cjs",
    "test:e2e": "playwright test",
    "test:unit": "playwright test -c playwright.unit.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "prisma:validate": "dotenv -e .env.local -- prisma validate --schema prisma/schema.prisma",
    "prisma:format": "dotenv -e .env.local -- prisma format --schema prisma/schema.prisma",
    "prisma:generate": "node scripts/prisma-generate-safe.cjs",
    "prisma:db:pull": "echo '⚠️  אזהרה: פקודה זו יכולה לדרוס את schema.prisma! השתמש בזהירות.' && dotenv -e .env.local -- prisma db pull --schema prisma/schema.prisma",
    "prisma:migrate:dev": "echo '❌ חסום! השתמש ב: npm run migrate:safe <שם-מיגריישן>' && exit 1",
    "prisma:migrate:reset": "echo '❌ חסום! פקודה זו מוחקת את כל הנתונים! אם אתה בטוח, הרץ ידנית: npx prisma migrate reset' && exit 1",
    "prisma:db:push": "echo '⚠️  אזהרה: פקודה מסוכנת! מעדיף: npm run migrate:safe' && dotenv -e .env.local -- prisma db push --schema prisma/schema.prisma",
    "prisma:studio": "dotenv -e .env.local -- prisma studio --schema prisma/schema.prisma",
    "db:push:dev": "dotenv -e .env.local -- prisma db push --schema prisma/schema.prisma",
    "db:seed:dev": "dotenv -e .env.local -- prisma db seed",
    "db:studio:dev": "dotenv -e .env.local -- prisma studio --schema prisma/schema.prisma",
    "PROTECTED:db:push:prod": "echo '⚠️⚠️⚠️ אתה בטוח? זה מסד הנתונים של PROD! ⚠️⚠️⚠️' && dotenv -e .env.prod_backup -- prisma db push --schema prisma/schema.prisma",
    "PROTECTED:db:seed:prod": "echo '⚠️⚠️⚠️ אתה בטוח? זה מסד הנתונים של PROD! ⚠️⚠️⚠️' && dotenv -e .env.prod_backup -- prisma db seed",
    "migrate:check": "node scripts/pre-migrate-check.js",
    "migrate:safe": "node scripts/safe-migrate.js",
    "db:backup": "node scripts/auto-backup.js",
    "db:backup:check": "node scripts/weekly-backup-reminder.js",
    "db:backup:critical": "node scripts/db-backup-critical.js",
    "db:restore": "node scripts/restore-backup.js",
    "db:restore:sql": "dotenv -e .env.local -- psql $DATABASE_URL -f scripts/db-restore-from-backup.sql",
    "db:check:status": "node scripts/db-check-status.js",
    "db:run:sql": "echo '❌ השתמש ב: npm run sql:safe <קובץ>' && exit 1",
    "sql:safe": "node scripts/safe-sql.js",
    "db:create:demos": "node scripts/create-demo-organizations.js",
    "db:create:all": "node scripts/safe-sql.js scripts/create-demo-user-and-orgs.sql",
    "db:check:user": "node scripts/run-query.js",
    "db:find:me": "node scripts/find-my-user.js",
    "db:check:id": "node scripts/check-user-by-id.js",
    "db:check:connection": "node scripts/show-db-connection.js",
    "db:check:migrations": "node scripts/check-prisma-history.js",
    "db:create:my-user": "node scripts/create-my-user-v2.js",
    "db:link:owner": "node scripts/link-owner-clerk-user.js",
    "generate-icons": "node scripts/generate-icons.js",
    "generate-brand-assets": "node scripts/generate-brand-assets.js",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:4000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "build:windows": "electron-builder --win",
    "build:android": "(npx cap add android || echo Android platform already exists) && npx cap sync android",
    "protect:middleware": "node scripts/protect-middleware.js",
    "check:middleware": "node scripts/monitor-middleware-protection.js",
    "remotion:preview": "remotion preview remotion/index.ts",
    "remotion:render": "remotion render remotion/index.ts",
    "remotion:render:all": "node scripts/remotion-render-all.js",
    "remotion-v2:preview": "remotion preview remotion-v2/index.ts",
    "remotion-v2:render": "remotion render remotion-v2/index.ts",
    "remotion-v2:render:all": "node scripts/remotion-v2-render-all.js",
    "remotion:upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.1",
    "@ai-sdk/react": "^3.0.3",
    "@capacitor/app": "^7.1.1",
    "@capacitor/core": "^7.4.5",
    "@clerk/localizations": "^3.36.0",
    "@clerk/nextjs": "^6.36.2",
    "@google/genai": "^1.33.0",
    "@hebcal/core": "^6.0.6",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@remotion/cli": "^4.0.424",
    "@remotion/google-fonts": "^4.0.424",
    "@sentry/nextjs": "^10.36.0",
    "@supabase/supabase-js": "^2.89.0",
    "@tanstack/react-query": "^5.90.20",
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/recharts": "^1.8.29",
    "@upstash/redis": "^1.35.0",
    "@zxing/browser": "^0.1.5",
    "ai": "^6.0.3",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.23.26",
    "google-auth-library": "^10.5.0",
    "googleapis": "^169.0.0",
    "lucide-react": "^0.561.0",
    "next": "16.0.10",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.69.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.6.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remotion": "^4.0.424",
    "resend": "^6.6.0",
    "svix": "^1.82.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.2.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.19.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "baseline-browser-mapping": "^2.9.19",
    "concurrently": "^8.2.2",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.25.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "html-docx-js": "^0.3.1",
    "html-to-docx": "^1.8.0",
    "marked": "^17.0.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "@google/genai": {
      "minimatch": "^10.2.1"
    },
    "@sentry/nextjs": {
      "minimatch": "^10.2.1"
    },
    "bn.js": "^5.2.3"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.misrad.ai",
    "productName": "MISRAD AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "app/favicon.ico",
      "app/icon.ico",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "app/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon-512.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon-512.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "language": "1037",
      "multiLanguageInstaller": true,
      "displayLanguageSelector": true,
      "installerIcon": "app/icon.ico",
      "uninstallerIcon": "app/icon.ico",
      "shortcutName": "MISRAD AI",
      "uninstallDisplayName": "MISRAD AI",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
