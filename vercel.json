{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/employee-invite-emails",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/check-trial-expiry",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/send-trial-warnings",
      "schedule": "0 9,17 * * *"
    },
    {
      "path": "/api/cron/attendance-monthly-reports",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/monthly-billing",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/ai-credits-renewal",
      "schedule": "0 5 1 * *"
    },
    {
      "path": "/api/cron/abandoned-signups",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/onboarding-followups",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/refresh-tokens",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/storage-cleanup",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "app/api/workspaces/*/system/call-analyzer/transcribe/route.ts": {
      "maxDuration": 120
    },
    "app/api/workspaces/*/system/call-analyzer/suggest/route.ts": {
      "maxDuration": 60
    },
    "app/api/workspaces/*/ai/transcribe/route.ts": {
      "maxDuration": 120
    },
    "app/api/client-os/meetings/process/route.ts": {
      "maxDuration": 120
    }
  },
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(self), geolocation=(self), payment=(self)"
        }
      ]
    }
  ]
}
