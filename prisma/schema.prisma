  total_duration_ms Int       @default(0)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  page_views SiteAnalyticsPageView[]
  events     SiteAnalyticsEvent[]

  @@index([visitor_id])
  @@index([created_at])
  @@index([signup_user_id])
  @@index([referrer])
  @@index([landing_page])
  @@map("site_analytics_sessions")
}

model SiteAnalyticsPageView {
  id              String               @id @default(cuid())
  session_id      String
  session         SiteAnalyticsSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  path            String
  title           String?
  referrer_page   String?
  time_on_page_ms Int                  @default(0)
  max_scroll_pct  Int                  @default(0)
  entered_at      DateTime             @default(now()) @db.Timestamptz(6)
  left_at         DateTime?            @db.Timestamptz(6)

  @@index([session_id])
  @@index([path])
  @@index([entered_at])
  @@map("site_analytics_page_views")
}

model SiteAnalyticsEvent {
  id         String               @id @default(cuid())
  session_id String
  session    SiteAnalyticsSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  event_type String
  event_data Json?
  page_path  String?
  created_at DateTime             @default(now()) @db.Timestamptz(6)

  @@index([session_id])
  @@index([event_type])
  @@index([created_at])
  @@map("site_analytics_events")
}

// ═══════════════════════════════════════════════════════════════════
// CUSTOMER RATINGS & EMAIL TRACKING
// ═══════════════════════════════════════════════════════════════════

model CustomerRating {
  id              String   @id @default(cuid())
  organization_id String   @db.Uuid
  user_id         String   @db.Uuid
  rating          Int // 1-5 stars
  feedback        String? // Optional text feedback
  google_clicked  Boolean  @default(false)
  source          String   @default("in_app") // in_app | email | direct
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  organization Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user         OrganizationUser @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, user_id])
  @@index([organization_id])
  @@index([created_at])
  @@map("customer_ratings")
}

model EmailSentLog {
  id              String   @id @default(cuid())
  email_type_id   String // matches EMAIL_CATALOG id
  recipient_email String
  organization_id String?  @db.Uuid
  user_id         String?  @db.Uuid
  status          String   @default("sent") // sent | failed | bounced
  metadata        Json?    @default("{}")
  sent_at         DateTime @default(now()) @db.Timestamptz(6)

  @@index([email_type_id])
  @@index([organization_id])
  @@index([recipient_email])
  @@index([sent_at])
  @@map("email_sent_logs")
}

// ═══════════════════════════════════════════════════════════════════
// LEGACY MODELS (1)
// ═══════════════════════════════════════════════════════════════════

model notifications {
  id          String    @id(map: "social_notifications_pkey") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String?   @db.Uuid
  title       String
  message     String
  type        String?   @default("info")
  is_read     Boolean?  @default(false)
  target_type String?   @default("all")
  target_id   String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  read_at     DateTime? @db.Timestamptz(6)
}

/// Marketing strategies generated by AI for Social module clients
model ClientMarketingStrategy {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId        String   @map("client_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  strategyData    Json     @map("strategy_data")
  profileData     Json     @map("profile_data")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([clientId], map: "idx_cms_client")
  @@index([organizationId], map: "idx_cms_org")
  @@map("client_marketing_strategy")
}
