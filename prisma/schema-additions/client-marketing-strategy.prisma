// Add this to the end of prisma/schema.prisma

/// Marketing strategies generated by AI for Social module clients
model ClientMarketingStrategy {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId        String   @map("client_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  strategyData    Json     @map("strategy_data")
  profileData     Json     @map("profile_data")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([clientId], map: "idx_cms_client")
  @@index([organizationId], map: "idx_cms_org")
  @@map("client_marketing_strategy")
}
