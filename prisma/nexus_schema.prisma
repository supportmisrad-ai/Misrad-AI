// ============================================
// 🚀 NEXUS DATABASE SCHEMA (נקסוס)
// ============================================
// This schema contains all tables for Nexus OS / Scale CRM
// All tables belong to Nexus system (not System/CRM system)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 🚀 NEXUS TABLES
// ============================================

// 👤 Nexus Users - משתמשים (שייך לנקסוס)
model NexusUser {
  id                      String    @id @default(uuid())
  name                    String
  role                    String
  department              String?
  avatar                  String?
  online                  Boolean   @default(false)
  capacity                Int       @default(0)
  email                   String?
  phone                   String?
  location                String?
  bio                     String?
  
  // Payroll Info
  paymentType             String?   @map("payment_type") // 'hourly' | 'monthly'
  hourlyRate              Decimal?  @map("hourly_rate") @db.Decimal(10, 2)
  monthlySalary           Decimal?  @map("monthly_salary") @db.Decimal(10, 2)
  
  // Incentives & Gamification
  commissionPct           Int?      @map("commission_pct")
  bonusPerTask            Decimal?  @map("bonus_per_task") @db.Decimal(10, 2)
  accumulatedBonus        Decimal   @default(0) @map("accumulated_bonus") @db.Decimal(10, 2)
  streakDays              Int       @default(0) @map("streak_days")
  weeklyScore             Decimal?  @map("weekly_score") @db.Decimal(5, 2)
  pendingReward           Json?     @map("pending_reward")
  
  // Targets & Preferences
  targets                 Json?
  notificationPreferences Json?     @map("notification_preferences")
  twoFactorEnabled        Boolean   @default(false) @map("two_factor_enabled")
  isSuperAdmin            Boolean   @default(false) @map("is_super_admin")
  billingInfo             Json?     @map("billing_info")
  
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  
  // Relations
  tasks                   NexusTask[]
  tasksAsCreator          NexusTask[] @relation("TaskCreator")
  timeEntries             NexusTimeEntry[]
  timeEntriesVoided       NexusTimeEntry[] @relation("TimeEntryVoidedBy")
  
  @@map("users")
  @@index([email])
  @@index([department])
  @@index([role])
}

// 🏢 Nexus Clients - לקוחות (שייך לנקסוס)
model NexusClient {
  id                String     @id @default(uuid())
  name              String
  companyName       String     @map("company_name")
  avatar            String?
  package           String?
  status            String     @default("Onboarding") // 'Active' | 'Onboarding' | 'Paused'
  contactPerson     String     @map("contact_person")
  email             String
  phone             String
  joinedAt          DateTime   @default(now()) @map("joined_at")
  assetsFolderUrl   String?    @map("assets_folder_url")
  source            String?
  
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  
  // Relations
  tasks             NexusTask[]
  
  @@map("clients")
  @@index([email])
  @@index([status])
  @@index([companyName])
}

// ✅ Nexus Tasks - משימות (שייך לנקסוס)
model NexusTask {
  id                String     @id @default(uuid())
  title             String
  description       String?
  status            String
  priority          String?    // 'Low' | 'Medium' | 'High' | 'Urgent'
  assigneeIds       String[]   @default([]) @map("assignee_ids") // UUID array
  assigneeId        String?    @map("assignee_id") // Legacy support - FK to NexusUser
  creatorId         String?    @map("creator_id") // FK to NexusUser
  tags              String[]   @default([])
  createdAt         DateTime   @default(now()) @map("created_at")
  dueDate           DateTime?  @map("due_date") @db.Date
  dueTime           String?    @map("due_time") @db.Time
  timeSpent         Int        @default(0) @map("time_spent") // in seconds
  estimatedTime     Int?       @map("estimated_time") // in minutes
  approvalStatus    String?    @map("approval_status") // 'pending' | 'approved' | 'rejected'
  isTimerRunning    Boolean    @default(false) @map("is_timer_running")
  messages          Json       @default("[]")
  clientId          String?    @map("client_id") // FK to NexusClient
  isPrivate         Boolean    @default(false) @map("is_private")
  audioUrl          String?    @map("audio_url")
  snoozeCount       Int        @default(0) @map("snooze_count")
  isFocus           Boolean    @default(false) @map("is_focus")
  completionDetails Json?      @map("completion_details")
  department        String?
  
  updatedAt         DateTime   @updatedAt @map("updated_at")
  
  // Relations
  assignee          NexusUser?  @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  creator           NexusUser?  @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  client            NexusClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  @@map("tasks")
  @@index([status])
  @@index([assigneeId])
  @@index([clientId])
  @@index([createdAt])
  @@index([dueDate])
}

// ⏱️ Nexus Time Entry - רשומות זמן (שייך לנקסוס)
model NexusTimeEntry {
  id                String     @id @default(uuid())
  userId            String     @map("user_id") // FK to NexusUser (required)
  startTime         DateTime   @map("start_time")
  endTime           DateTime?  @map("end_time")
  date              DateTime   @db.Date
  durationMinutes   Int?       @map("duration_minutes")
  
  // Audit Trail Fields
  voidReason        String?    @map("void_reason")
  voidedBy          String?    @map("voided_by") // FK to NexusUser
  voidedAt          DateTime?  @map("voided_at")
  
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  
  // Relations
  user              NexusUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  voidedByUser      NexusUser?  @relation("TimeEntryVoidedBy", fields: [voidedBy], references: [id], onDelete: SetNull)
  
  @@map("time_entries")
  @@index([userId])
  @@index([date])
  @@index([startTime])
}

// 🏛️ Nexus Tenant - דיירים (SaaS Multi-tenancy) (שייך לנקסוס)
model NexusTenant {
  id                String     @id @default(uuid())
  name              String
  ownerEmail        String     @map("owner_email")
  subdomain         String     @unique
  plan              String
  status            String     @default("Provisioning") // 'Active' | 'Trial' | 'Churned' | 'Provisioning'
  joinedAt          DateTime   @default(now()) @map("joined_at")
  mrr               Decimal    @default(0) @db.Decimal(10, 2)
  usersCount        Int        @default(0) @map("users_count")
  logo              String?
  modules           String[]   @default([])
  region            String?    // 'eu-west' | 'us-east' | 'il-central'
  version           String?
  allowedEmails     String[]   @default([]) @map("allowed_emails")
  requireApproval   Boolean    @default(false) @map("require_approval")
  
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  
  @@map("tenants")
  @@index([subdomain])
  @@index([status])
  @@index([ownerEmail])
}

