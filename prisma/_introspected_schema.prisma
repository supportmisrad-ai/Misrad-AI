generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NexusUser {
  id                      String    @id(map: "users_pkey") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                    String
  role                    String
  department              String?
  avatar                  String?
  online                  Boolean?  @default(false)
  capacity                Int?      @default(0)
  email                   String?
  phone                   String?
  location                String?
  bio                     String?
  paymentType             String?   @map("payment_type")
  hourlyRate              Decimal?  @map("hourly_rate") @db.Decimal(10, 2)
  monthlySalary           Decimal?  @map("monthly_salary") @db.Decimal(10, 2)
  commissionPct           Int?      @map("commission_pct")
  bonusPerTask            Decimal?  @map("bonus_per_task") @db.Decimal(10, 2)
  accumulatedBonus        Decimal?  @default(0) @map("accumulated_bonus") @db.Decimal(10, 2)
  streakDays              Int?      @default(0) @map("streak_days")
  weeklyScore             Decimal?  @map("weekly_score") @db.Decimal(5, 2)
  pendingReward           Json?     @map("pending_reward")
  targets                 Json?
  notificationPreferences Json?     @map("notification_preferences")
  twoFactorEnabled        Boolean?  @default(false) @map("two_factor_enabled")
  isSuperAdmin            Boolean?  @default(false) @map("is_super_admin")
  billingInfo             Json?     @map("billing_info")
  createdAt               DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  managerId               String?   @map("manager_id") @db.Uuid
  roleId                  String?   @map("role_id") @db.Uuid
  managed_department      String?
  uiPreferences           Json?     @default("{}") @map("ui_preferences")

  @@index([department], map: "idx_users_department")
  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
  @@map("nexus_users")
}

model NexusClient {
  id              String   @id(map: "clients_pkey") @default(uuid())
  name            String
  companyName     String   @map("company_name")
  avatar          String?
  package         String?
  status          String   @default("Onboarding")
  contactPerson   String   @map("contact_person")
  email           String
  phone           String
  joinedAt        DateTime @default(now()) @map("joined_at")
  assetsFolderUrl String?  @map("assets_folder_url")
  source          String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([companyName], map: "idx_clients_company_name")
  @@index([email], map: "idx_clients_email")
  @@map("nexus_clients")
}

model NexusTask {
  id                String    @id(map: "tasks_pkey") @default(uuid())
  title             String
  description       String?
  status            String
  priority          String?
  assigneeIds       String[]  @default([]) @map("assignee_ids")
  assigneeId        String?   @map("assignee_id")
  creatorId         String?   @map("creator_id")
  tags              String[]  @default([])
  createdAt         DateTime  @default(now()) @map("created_at")
  dueDate           DateTime? @map("due_date") @db.Date
  dueTime           DateTime? @map("due_time") @db.Time(6)
  timeSpent         Int       @default(0) @map("time_spent")
  estimatedTime     Int?      @map("estimated_time")
  approvalStatus    String?   @map("approval_status")
  isTimerRunning    Boolean   @default(false) @map("is_timer_running")
  messages          Json      @default("[]")
  clientId          String?   @map("client_id")
  isPrivate         Boolean   @default(false) @map("is_private")
  audioUrl          String?   @map("audio_url")
  snoozeCount       Int       @default(0) @map("snooze_count")
  isFocus           Boolean   @default(false) @map("is_focus")
  completionDetails Json?     @map("completion_details")
  department        String?
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([assigneeId], map: "idx_tasks_assignee_id")
  @@index([clientId], map: "idx_tasks_client_id")
  @@index([createdAt], map: "idx_tasks_created_at")
  @@index([dueDate], map: "idx_tasks_due_date")
  @@index([status], map: "idx_tasks_status")
  @@map("nexus_tasks")
}

model NexusTimeEntry {
  id              String    @id(map: "time_entries_pkey") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  startTime       DateTime  @map("start_time") @db.Timestamptz(6)
  endTime         DateTime? @map("end_time") @db.Timestamptz(6)
  date            DateTime  @db.Date
  durationMinutes Int?      @map("duration_minutes")
  voidReason      String?   @map("void_reason")
  voidedBy        String?   @map("voided_by") @db.Uuid
  voidedAt        DateTime? @map("voided_at") @db.Timestamptz(6)
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([date], map: "idx_time_entries_date")
  @@index([startTime], map: "idx_time_entries_start_time")
  @@index([userId], map: "idx_time_entries_user_id")
  @@map("nexus_time_entries")
}

model NexusTenant {
  id              String    @id(map: "tenants_pkey") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String
  ownerEmail      String    @map("owner_email")
  subdomain       String    @unique(map: "tenants_subdomain_key")
  plan            String
  status          String?   @default("Provisioning")
  joinedAt        DateTime? @default(now()) @map("joined_at") @db.Timestamptz(6)
  mrr             Decimal?  @default(0) @db.Decimal(10, 2)
  usersCount      Int?      @default(0) @map("users_count")
  logo            String?
  modules         String[]  @default([])
  region          String?
  version         String?
  allowedEmails   String[]  @default([]) @map("allowed_emails")
  requireApproval Boolean?  @default(false) @map("require_approval")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([ownerEmail], map: "idx_tenants_owner_email")
  @@index([status], map: "idx_tenants_status")
  @@index([subdomain], map: "idx_tenants_subdomain")
  @@map("nexus_tenants")
}

model SystemLead {
  id                  String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                String
  company             String?
  phone               String
  email               String
  source              String
  status              String
  value               Decimal?               @default(0) @db.Decimal(10, 2)
  lastContact         DateTime               @map("last_contact") @db.Timestamptz(6)
  createdAt           DateTime?              @default(now()) @map("created_at") @db.Timestamptz(6)
  isHot               Boolean?               @default(false) @map("is_hot")
  score               Int?                   @default(0)
  address             String?
  locationX           Decimal?               @map("location_x") @db.Decimal(10, 6)
  locationY           Decimal?               @map("location_y") @db.Decimal(10, 6)
  assignedAgentId     String?                @map("assigned_agent_id") @db.Uuid
  subscriptionEndDate DateTime?              @map("subscription_end_date") @db.Timestamptz(6)
  productInterest     String?                @map("product_interest")
  playbookStep        String?                @map("playbook_step")
  budgetHours         Int?                   @map("budget_hours")
  loggedHours         Int?                   @map("logged_hours")
  aiTags              Json?                  @default("[]") @map("ai_tags")
  updatedAt           DateTime?              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  calendarEvents      SystemCalendarEvent[]
  callAnalyses        SystemCallAnalysis[]
  invoices            SystemInvoice[]
  activities          SystemLeadActivity[]
  handover            SystemLeadHandover?
  portalApprovals     SystemPortalApproval[]
  portalTasks         SystemPortalTask[]
  supportTickets      SystemSupportTicket[]

  @@index([assignedAgentId], map: "idx_system_leads_assigned_agent_id")
  @@index([createdAt], map: "idx_system_leads_created_at")
  @@index([isHot], map: "idx_system_leads_is_hot")
  @@index([status], map: "idx_system_leads_status")
  @@map("system_leads")
}

model SystemLeadActivity {
  id        String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  leadId    String     @map("lead_id") @db.Uuid
  type      String
  content   String
  timestamp DateTime?  @default(now()) @db.Timestamptz(6)
  direction String?
  metadata  Json?
  createdAt DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  lead      SystemLead @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([leadId], map: "idx_system_lead_activities_lead_id")
  @@index([timestamp], map: "idx_system_lead_activities_timestamp")
  @@map("system_lead_activities")
}

model SystemLeadHandover {
  id                  String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  leadId              String     @unique @map("lead_id") @db.Uuid
  nonStandardPromises String     @map("non_standard_promises")
  biggestPain         String     @map("biggest_pain")
  expectations30Days  String     @map("expectations_30_days")
  filledAt            DateTime?  @default(now()) @map("filled_at") @db.Timestamptz(6)
  createdAt           DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lead                SystemLead @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("system_lead_handovers")
}

model SystemTask {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title       String
  description String?
  assigneeId  String    @map("assignee_id") @db.Uuid
  dueDate     DateTime  @map("due_date") @db.Timestamptz(6)
  priority    String
  status      String
  tags        Json?     @default("[]")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([assigneeId], map: "idx_system_tasks_assignee_id")
  @@index([dueDate], map: "idx_system_tasks_due_date")
  @@index([status], map: "idx_system_tasks_status")
  @@map("system_tasks")
}

model SystemInvoice {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  leadId       String?     @map("lead_id") @db.Uuid
  client       String
  amount       Decimal     @db.Decimal(10, 2)
  date         DateTime?   @default(now()) @db.Timestamptz(6)
  status       String
  item         String
  refundReason String?     @map("refund_reason")
  createdAt    DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lead         SystemLead? @relation(fields: [leadId], references: [id], onUpdate: NoAction)

  @@index([date], map: "idx_system_invoices_date")
  @@index([leadId], map: "idx_system_invoices_lead_id")
  @@index([status], map: "idx_system_invoices_status")
  @@map("system_invoices")
}

model SystemCalendarEvent {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  leadId       String?     @map("lead_id") @db.Uuid
  title        String
  leadName     String      @map("lead_name")
  leadCompany  String      @map("lead_company")
  dayName      String      @map("day_name")
  date         String
  time         String
  type         String
  location     String
  participants Int?
  reminders    Json?
  postMeeting  Json?       @map("post_meeting")
  createdAt    DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lead         SystemLead? @relation(fields: [leadId], references: [id], onUpdate: NoAction)

  @@index([date], map: "idx_system_calendar_events_date")
  @@index([leadId], map: "idx_system_calendar_events_lead_id")
  @@map("system_calendar_events")
}

model SystemCampaign {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  platform    String
  status      String
  budget      Decimal?  @default(0) @db.Decimal(10, 2)
  spent       Decimal?  @default(0) @db.Decimal(10, 2)
  leads       Int?      @default(0)
  cpl         Decimal?  @default(0) @db.Decimal(10, 2)
  roas        Decimal?  @default(0) @db.Decimal(10, 2)
  impressions Int?      @default(0)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([createdAt], map: "idx_system_campaigns_created_at")
  @@index([status], map: "idx_system_campaigns_status")
  @@map("system_campaigns")
}

model SystemStudent {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  company     String
  avatar      String
  progress    Int?      @default(0)
  status      String
  cohort      String
  lastCheckIn DateTime  @map("last_check_in") @db.Timestamptz(6)
  nextHotSeat DateTime? @map("next_hot_seat") @db.Timestamptz(6)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([cohort], map: "idx_system_students_cohort")
  @@index([status], map: "idx_system_students_status")
  @@map("system_students")
}

model SystemContentItem {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title     String
  format    String
  platform  String
  status    String
  assignee  String
  views     Int?      @default(0)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([platform], map: "idx_system_content_items_platform")
  @@index([status], map: "idx_system_content_items_status")
  @@map("system_content_items")
}

model SystemFieldAgent {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  name        String
  status      String
  locationX   Decimal   @map("location_x") @db.Decimal(10, 6)
  locationY   Decimal   @map("location_y") @db.Decimal(10, 6)
  avatar      String
  phone       String
  area        String
  currentTask String?   @map("current_task")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status], map: "idx_system_field_agents_status")
  @@index([userId], map: "idx_system_field_agents_user_id")
  @@map("system_field_agents")
}

model SystemWebhookLog {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  timestamp DateTime? @default(now()) @db.Timestamptz(6)
  channel   String
  event     String
  status    String

  @@index([channel], map: "idx_system_webhook_logs_channel")
  @@index([timestamp], map: "idx_system_webhook_logs_timestamp")
  @@map("system_webhook_logs")
}

model SystemCallAnalysis {
  id         String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  leadId     String?     @map("lead_id") @db.Uuid
  fileName   String      @map("file_name")
  title      String
  audioUrl   String      @map("audio_url")
  date       String
  duration   String
  summary    String
  score      Int?        @default(0)
  intent     String
  userNotes  String?     @map("user_notes")
  transcript Json?       @default("[]")
  topics     Json?       @default("{}")
  feedback   Json?       @default("{}")
  createdAt  DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lead       SystemLead? @relation(fields: [leadId], references: [id], onUpdate: NoAction)

  @@index([date], map: "idx_system_call_analyses_date")
  @@index([leadId], map: "idx_system_call_analyses_lead_id")
  @@index([score], map: "idx_system_call_analyses_score")
  @@map("system_call_analyses")
}

model SystemAutomation {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String
  enabled       Boolean?  @default(true)
  triggerType   String    @map("trigger_type")
  triggerStatus String?   @map("trigger_status")
  actionType    String    @map("action_type")
  taskTitle     String?   @map("task_title")
  taskDueDays   Int?      @map("task_due_days")
  taskPriority  String?   @map("task_priority")
  noteText      String?   @map("note_text")
  runs          Int?      @default(0)
  lastRun       DateTime? @map("last_run") @db.Timestamptz(6)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([enabled], map: "idx_system_automations_enabled")
  @@index([triggerType], map: "idx_system_automations_trigger_type")
  @@map("system_automations")
}

model SystemForm {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title       String
  status      String
  views       Int?      @default(0)
  conversions Int?      @default(0)
  fields      Json?     @default("[]")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([createdAt], map: "idx_system_forms_created_at")
  @@index([status], map: "idx_system_forms_status")
  @@map("system_forms")
}

model SystemPartner {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String
  type             String
  referrals        Int?      @default(0)
  revenue          Decimal?  @default(0) @db.Decimal(10, 2)
  commissionRate   Decimal?  @default(0) @map("commission_rate") @db.Decimal(5, 2)
  unpaidCommission Decimal?  @default(0) @map("unpaid_commission") @db.Decimal(10, 2)
  lastActive       String    @map("last_active")
  avatar           String
  status           String
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status], map: "idx_system_partners_status")
  @@index([type], map: "idx_system_partners_type")
  @@map("system_partners")
}

model SystemAsset {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title       String
  description String?
  category    String
  type        String
  value       String
  isSecure    Boolean?  @default(false) @map("is_secure")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([category], map: "idx_system_assets_category")
  @@index([type], map: "idx_system_assets_type")
  @@map("system_assets")
}

model SystemPortalApproval {
  id        String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  leadId    String     @map("lead_id") @db.Uuid
  type      String
  title     String
  date      String
  status    String
  createdAt DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lead      SystemLead @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([leadId], map: "idx_system_portal_approvals_lead_id")
  @@index([status], map: "idx_system_portal_approvals_status")
  @@map("system_portal_approvals")
}

model SystemPortalTask {
  id         String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  leadId     String     @map("lead_id") @db.Uuid
  title      String
  type       String
  status     String
  formFields Json?      @default("[]") @map("form_fields")
  createdAt  DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lead       SystemLead @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([leadId], map: "idx_system_portal_tasks_lead_id")
  @@index([status], map: "idx_system_portal_tasks_status")
  @@map("system_portal_tasks")
}

model SystemSupportTicket {
  id        String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  leadId    String     @map("lead_id") @db.Uuid
  category  String
  subject   String
  status    String
  createdAt DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lead      SystemLead @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([category], map: "idx_system_support_tickets_category")
  @@index([leadId], map: "idx_system_support_tickets_lead_id")
  @@index([status], map: "idx_system_support_tickets_status")
  @@map("system_support_tickets")
}

model SocialPost {
  id                     String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clientId               String                   @map("client_id") @db.Uuid
  content                String
  media_url              String?
  status                 String?                  @default("draft")
  scheduled_at           DateTime?                @db.Timestamptz(6)
  published_at           DateTime?                @db.Timestamptz(6)
  is_late                Boolean?                 @default(false)
  created_by             String?                  @db.Uuid
  createdAt              DateTime?                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime?                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deleted_at             DateTime?                @db.Timestamptz(6)
  deleted_by             String?                  @db.Uuid
  social_post_comments   social_post_comments[]
  social_post_platforms  social_post_platforms[]
  social_post_variations social_post_variations[]

  @@index([clientId], map: "idx_social_posts_client_id")
  @@index([status], map: "idx_social_posts_status")
  @@map("social_posts")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model nexus_employee_invitation_links {
  id             String    @id(map: "employee_invitation_links_pkey") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  token          String    @unique(map: "employee_invitation_links_token_key")
  created_by     String?   @db.Uuid
  department     String?
  role           String?
  employee_email String?
  employee_name  String?
  employee_phone String?
  payment_type   String?
  hourly_rate    Decimal?  @db.Decimal(10, 2)
  monthly_salary Decimal?  @db.Decimal(10, 2)
  commission_pct Int?
  start_date     DateTime? @db.Date
