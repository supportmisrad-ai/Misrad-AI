// ============================================
// SYSTEM DATABASE SCHEMA (מערכת System)
// ============================================
// This schema contains all tables required for the System (CRM/Sales System)
// All tables are prefixed with "system_" to distinguish from Nexus tables
// ============================================

// ============================================
// MAIN ENTITIES
// ============================================

// System Lead - לידים (שייך למערכת System)
model SystemLead {
  id                    String   @id @default(cuid())
  organization_id        String
  customer_account_id    String?
  name                  String
  company               String?
  phone                 String
  email                 String
  source                String   // מקור הליד
  status                String   // PipelineStage: 'incoming' | 'contacted' | 'meeting' | 'proposal' | 'negotiation' | 'won' | 'lost' | 'churned'
  value                 Float    @default(0) // ערך עסקה
  lastContact           DateTime
  createdAt             DateTime @default(now())
  isHot                 Boolean  @default(false)
  score                 Int      @default(0) // ציון ליד
  
  // Optional fields
  address               String?
  locationX             Float?   // קואורדינטה X למיקום
  locationY             Float?   // קואורדינטה Y למיקום
  assignedAgentId       String?  // FK to User (Nexus) - נציג משויך
  subscriptionEndDate   DateTime?
  productInterest       String?  // ProductType: 'premium_1on1' | 'mastermind_group' | 'digital_course'
  playbookStep          String?
  budgetHours           Int?
  loggedHours           Int?
  
  // JSON fields
  aiTags                Json?    @default("[]") // Array of strings
  
  // Relations
  activities            SystemLeadActivity[]
  handover              SystemLeadHandover?
  calendarEvents        SystemCalendarEvent[]
  callAnalyses          SystemCallAnalysis[]
  portalApprovals       SystemPortalApproval[]
  portalTasks           SystemPortalTask[]
  supportTickets        SystemSupportTicket[]
  invoices              SystemInvoice[]
  
  @@map("system_leads")
  @@index([status])
  @@index([organization_id])
  @@index([assignedAgentId])
  @@index([createdAt])
  @@index([isHot])
}

// System Lead Activity - פעילויות של ליד (שייך למערכת System)
model SystemLeadActivity {
  id          String   @id @default(cuid())
  leadId      String   // FK to SystemLead
  type        String   // 'call' | 'whatsapp' | 'email' | 'meeting' | 'note' | 'system' | 'financial' | 'sms' | 'feedback' | 'support'
  content     String   @db.Text
  timestamp   DateTime @default(now())
  direction   String?  // 'inbound' | 'outbound'
  metadata    Json?    // Additional metadata
  
  // Relations
  lead        SystemLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  @@map("system_lead_activities")
  @@index([leadId])
  @@index([timestamp])
}

// System Lead Handover - העברת ליד (שייך למערכת System)
model SystemLeadHandover {
  id                  String   @id @default(cuid())
  leadId              String   @unique // FK to SystemLead (1:1 relationship)
  nonStandardPromises String   @db.Text
  biggestPain         String   @db.Text
  expectations30Days  String   @db.Text
  filledAt            DateTime @default(now())
  
  // Relations
  lead                SystemLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  @@map("system_lead_handovers")
}

// System Task - משימות (שייך למערכת System)
model SystemTask {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  assigneeId  String   // FK to User (Nexus) - משויך למשתמש
  dueDate     DateTime
  priority    String   // TaskPriority: 'low' | 'medium' | 'high' | 'critical'
  status      String   // TaskStatus: 'todo' | 'in_progress' | 'review' | 'done'
  
  // JSON fields
  tags        Json     @default("[]") // Array of strings
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("system_tasks")
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
}

// System Invoice - חשבוניות (שייך למערכת System)
model SystemInvoice {
  id            String   @id @default(cuid())
  leadId        String?  // FK to SystemLead (optional - might be created manually)
  client        String   // שם לקוח (יכול להיות גם טקסט חופשי)
  amount        Float
  date          DateTime @default(now())
  status        String   // 'paid' | 'pending' | 'overdue' | 'refunded'
  item          String   @db.Text // תיאור הפריט
  refundReason  String?  @db.Text
  
  // Relations
  lead          SystemLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("system_invoices")
  @@index([leadId])
  @@index([status])
  @@index([date])
}

// System Calendar Event - אירועי יומן (שייך למערכת System)
model SystemCalendarEvent {
  id            String   @id @default(cuid())
  leadId        String?  // FK to SystemLead (optional - might be general event)
  title         String
  leadName      String   // Denormalized for display
  leadCompany   String   // Denormalized for display
  dayName       String   // שם היום בעברית
  date          String   // ISO date string
  time          String   // Time string
  type          String   // 'zoom' | 'frontal' | 'group_session'
  location      String
  participants  Int?
  
  // JSON fields
  reminders     Json?    // { whatsapp: boolean, sms: boolean, email: boolean, timing: string }
  postMeeting   Json?    // { enabled: boolean, type: string, delay: string, channel: string }
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  lead          SystemLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  @@map("system_calendar_events")
  @@index([leadId])
  @@index([date])
}

// System Campaign - קמפיינים (שייך למערכת System)
model SystemCampaign {
  id          String   @id @default(cuid())
  name        String
  platform    String   // פלטפורמה
  status      String   // 'active' | 'paused' | 'draft'
  budget      Float    @default(0)
  spent       Float    @default(0)
  leads       Int      @default(0)
  cpl         Float    @default(0) // Cost Per Lead
  roas        Float    @default(0) // Return On Ad Spend
  impressions Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("system_campaigns")
  @@index([status])
  @@index([createdAt])
}

// System Student - סטודנטים (שייך למערכת System)
model SystemStudent {
  id          String   @id @default(cuid())
  name        String
  company     String
  avatar      String
  progress    Int      @default(0) // 0-100
  status      String   // 'on_track' | 'needs_help' | 'at_risk'
  cohort      String   // קבוצה/קוהורט
  lastCheckIn DateTime
  nextHotSeat DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("system_students")
  @@index([status])
  @@index([cohort])
}

// System Content Item - פריטי תוכן (שייך למערכת System)
model SystemContentItem {
  id          String   @id @default(cuid())
  title       String
  format      String   // 'pillar' | 'short'
  platform    String   // פלטפורמה
  status      String   // ContentStage: 'idea' | 'scripting' | 'filming' | 'editing' | 'ready' | 'published'
  assignee    String   // שם המשויך
  views       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("system_content_items")
  @@index([status])
  @@index([platform])
}

// System Field Agent - סוכני שדה (שייך למערכת System)
model SystemFieldAgent {
  id          String   @id @default(cuid())
  userId      String?  // FK to User (Nexus) - אופציונלי
  name        String
  status      String   // 'available' | 'busy' | 'offline'
  locationX   Float    // קואורדינטה X
  locationY   Float    // קואורדינטה Y
  avatar      String
  phone       String
  area        String   // אזור
  currentTask String?  // משימה נוכחית
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("system_field_agents")
  @@index([userId])
  @@index([status])
}

// System Webhook Log - לוגים של Webhooks (שייך למערכת System)
model SystemWebhookLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  channel   String   // ערוץ
  event     String   // שם האירוע
  status    String   // סטטוס
  
  @@map("system_webhook_logs")
  @@index([timestamp])
  @@index([channel])
}

// System Call Analysis - ניתוח שיחות (שייך למערכת System)
model SystemCallAnalysis {
  id        String   @id @default(cuid())
  leadId    String?  // FK to SystemLead (optional - might be unlinked)
  fileName  String
  title     String
  audioUrl  String
  date      String   // ISO date string
  duration  String   // משך זמן
  summary   String   @db.Text
  score     Int      @default(0) // ציון 0-100
  intent    String   // 'buying' | 'window_shopping' | 'angry' | 'churn_risk'
  userNotes String?  @db.Text
  
  // JSON fields - storing complex nested data
  transcript Json    @default("[]") // Array of { speaker: string, text: string, timestamp: number, sentiment: string }
  topics     Json    @default("{}") // { promises: string[], painPoints: string[], likes: string[], slang: string[], stories: string[], decisions: string[], tasks: string[] }
  feedback   Json    @default("{}") // { positive: string[], improvements: string[] }
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  // Relations
  lead       SystemLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  
  @@map("system_call_analyses")
  @@index([leadId])
  @@index([date])
  @@index([score])
}

// System Automation - אוטומציות (שייך למערכת System)
model SystemAutomation {
  id          String   @id @default(cuid())
  name        String
  enabled     Boolean  @default(true)
  
  // Trigger configuration (JSON)
  triggerType String   // 'lead_created' | 'status_changed'
  triggerStatus String? // PipelineStage (only if triggerType is 'status_changed')
  
  // Action configuration (JSON)
  actionType  String   // 'create_task' | 'add_note'
  taskTitle   String?  // Only if actionType is 'create_task'
  taskDueDays Int?     // Only if actionType is 'create_task'
  taskPriority String? // Only if actionType is 'create_task': 'low' | 'medium' | 'high' | 'critical'
  noteText    String?  @db.Text // Only if actionType is 'add_note'
  
  // Stats
  runs        Int      @default(0)
  lastRun     DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("system_automations")
  @@index([enabled])
  @@index([triggerType])
}

// System Form - טפסים (שייך למערכת System)
model SystemForm {
  id          String   @id @default(cuid())
  title       String
  status      String   // 'active' | 'draft'
  views       Int      @default(0)
  conversions Int      @default(0)
  
  // JSON fields
  fields      Json     @default("[]") // Array of FormField: { id: string, type: string, label: string, placeholder?: string, required: boolean, options?: string[] }
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("system_forms")
  @@index([status])
  @@index([createdAt])
}

// System Partner - שותפים (שייך למערכת System)
model SystemPartner {
  id                String   @id @default(cuid())
  name              String
  type              String   // 'affiliate' | 'customer' | 'influencer'
  referrals         Int      @default(0)
  revenue           Float    @default(0)
  commissionRate    Float    @default(0) // Percentage
  unpaidCommission  Float    @default(0)
  lastActive        String   // String representation
  avatar            String
  status            String   // 'active' | 'inactive'
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("system_partners")
  @@index([status])
  @@index([type])
}

// System Asset - נכסים (שייך למערכת System)
model SystemAsset {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  category    String   // 'all' | 'links' | 'passwords' | 'files' | 'templates'
  type        String   // 'link' | 'password' | 'file'
  value       String   @db.Text // The url, password, or file link
  isSecure    Boolean  @default(false) // Requires toggle to see
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("system_assets")
  @@index([category])
  @@index([type])
}

// ============================================
// CLIENT PORTAL ENTITIES
// ============================================

// System Portal Approval - אישורים בפורטל לקוח (שייך למערכת System)
model SystemPortalApproval {
  id        String   @id @default(cuid())
  leadId    String   // FK to SystemLead
  type      String   // 'proposal' | 'design' | 'contract' | 'feedback'
  title     String
  date      String   // ISO date string
  status    String   // 'waiting' | 'approved' | 'rejected'
  
  // Relations
  lead      SystemLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("system_portal_approvals")
  @@index([leadId])
  @@index([status])
}

// System Portal Task - משימות בפורטל לקוח (שייך למערכת System)
model SystemPortalTask {
  id        String   @id @default(cuid())
  leadId    String   // FK to SystemLead
  title     String
  type      String   // 'text' | 'form' | 'feedback' | 'support'
  status    String   // 'pending' | 'completed'
  
  // JSON fields
  formFields Json?   @default("[]") // Array of { id: string, label: string, type: string, options?: string[] }
  
  // Relations
  lead      SystemLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("system_portal_tasks")
  @@index([leadId])
  @@index([status])
}

// System Support Ticket - כרטיסי תמיכה (שייך למערכת System)
model SystemSupportTicket {
  id        String   @id @default(cuid())
  leadId    String   // FK to SystemLead
  category  String   // 'technical' | 'billing' | 'service' | 'other'
  subject   String
  status    String   // 'open' | 'in_progress' | 'closed'
  
  // Relations
  lead      SystemLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("system_support_tickets")
  @@index([leadId])
  @@index([status])
  @@index([category])
}

