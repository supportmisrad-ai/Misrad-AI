  client_documents client_documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  organizations    organizations    @relation(fields: [organization_id], references: [id])

  @@index([client_id], map: "idx_client_document_files_client_id")
  @@index([document_id], map: "idx_client_document_files_document_id")
