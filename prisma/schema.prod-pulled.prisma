  voice_formal         Int?
  voice_funny          Int?
  voice_length         Int?
  vocabulary_loved     Json?     @default("[]")
  vocabulary_forbidden Json?     @default("[]")
  color_primary        String?
  color_secondary      String?
  strategy             String?
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)
  clients              clients   @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model client_document_files {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id  String           @db.Uuid
  client_id        String           @db.Uuid
  document_id      String           @db.Uuid
  storage_bucket   String           @default("client")
  storage_path     String
  file_name        String?
