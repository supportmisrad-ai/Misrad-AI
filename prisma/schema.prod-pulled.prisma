generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model activity_logs {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  team_member_id String       @db.Uuid
  action         String
  target_id      String?      @db.Uuid
  target_type    String?
  created_at     DateTime?    @default(now()) @db.Timestamptz(6)
  user_id        String?
  team_members   team_members @relation(fields: [team_member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([team_member_id, created_at(sort: Desc)], map: "idx_social_activity_logs_team_member_created_at")
  @@index([team_member_id], map: "idx_social_activity_logs_team_member_id")
}

model ai_embeddings {
  id               String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id  String                @db.Uuid
  module_id        String
  user_id          String?
  is_public_in_org Boolean               @default(false)
  doc_key          String
  chunk_index      Int                   @default(0)
  content          String
  embedding        Unsupported("vector")
  metadata         Json?
  created_at       DateTime              @default(now()) @db.Timestamptz(6)
  updated_at       DateTime              @default(now()) @db.Timestamptz(6)
  organizations    organizations         @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([organization_id, doc_key, chunk_index])
  @@index([embedding], map: "idx_ai_embeddings_embedding_cosine")
  @@index([organization_id], map: "idx_ai_embeddings_org")
  @@index([organization_id, module_id], map: "idx_ai_embeddings_org_module")
  @@index([organization_id, user_id], map: "idx_ai_embeddings_org_user")
  @@index([organization_id, is_public_in_org], map: "idx_ai_embeddings_org_visibility")
}

model ai_feature_settings {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String?        @db.Uuid
  feature_key        String
  enabled            Boolean        @default(true)
  primary_provider   String
  primary_model      String
  fallback_provider  String?
  fallback_model     String?
  reserve_cost_cents Int            @default(25)
  timeout_ms         Int            @default(30000)
  created_at         DateTime       @default(now()) @db.Timestamptz(6)
  updated_at         DateTime       @default(now()) @db.Timestamptz(6)
  backup_provider    String?
  backup_model       String?
  base_prompt        String?
  organizations      organizations? @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([feature_key], map: "ai_feature_settings_feature_idx")
  @@index([organization_id], map: "ai_feature_settings_org_idx")
}

model ai_model_aliases {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider        String
  model           String
  organization_id String?        @db.Uuid
  display_name    String
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @default(now()) @db.Timestamptz(6)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organization_id], map: "ai_model_aliases_org_idx")
  @@index([provider, model])
}

model ai_provider_keys {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider        String
  organization_id String?        @db.Uuid
  api_key         String
  enabled         Boolean        @default(true)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @default(now()) @db.Timestamptz(6)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organization_id], map: "ai_provider_keys_org_idx")
  @@index([provider])
}

model ai_usage_logs {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at         DateTime      @default(now()) @db.Timestamptz(6)
  organization_id    String        @db.Uuid
  user_id            String
  feature_key        String
  task_kind          String
  provider           String
  model              String
  model_display_name String?
  charged_cents      Int           @default(0)
  latency_ms         Int?
  status             String
  error_message      String?
  meta               Json?
  organizations      organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([feature_key], map: "ai_usage_logs_feature_idx")
  @@index([organization_id, created_at(sort: Desc)], map: "ai_usage_logs_org_created_idx")
  @@index([provider])
}

model app_updates {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  version           String
  title             String
  description       String
  category          String
  priority          String?             @default("medium")
  is_published      Boolean?            @default(true)
  published_at      DateTime?           @default(now()) @db.Timestamptz(6)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  user_update_views user_update_views[]
}

model billing_events {
  id                  String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id     String         @db.Uuid
  subscription_id     String?        @db.Uuid
  event_type          String
  occurred_at         DateTime       @default(now()) @db.Timestamptz(6)
  actor_clerk_user_id String?
  payload             Json?
  created_at          DateTime?      @default(now()) @db.Timestamptz(6)
  organizations       organizations  @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subscriptions       subscriptions? @relation(fields: [subscription_id], references: [id], onUpdate: NoAction)

  @@index([organization_id], map: "idx_billing_events_org_id")
  @@index([subscription_id], map: "idx_billing_events_sub_id")
  @@index([event_type], map: "idx_billing_events_type")
}

model business_metrics {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id              String    @unique(map: "idx_business_metrics_client_id_unique") @db.Uuid
  time_spent_minutes     Int?      @default(0)
  expected_hours         Decimal?  @default(0) @db.Decimal(5, 2)
  punctuality_score      Int?      @default(0)
  responsiveness_score   Int?      @default(0)
  revision_count         Int?      @default(0)
  last_ai_business_audit String?
  days_overdue           Int?      @default(0)
  created_at             DateTime? @default(now()) @db.Timestamptz(6)
  updated_at             DateTime? @default(now()) @db.Timestamptz(6)
  clients                clients   @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([client_id], map: "idx_business_metrics_client_id")
}

model charges {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id String         @db.Uuid
  subscription_id String?        @db.Uuid
  provider        String         @default("manual")
  status          String         @default("pending")
  amount          Decimal        @default(0) @db.Decimal(10, 2)
  currency        String?        @default("ILS")
  external_id     String?
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?      @default(now()) @db.Timestamptz(6)
  metadata        Json?
  organizations   organizations  @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subscriptions   subscriptions? @relation(fields: [subscription_id], references: [id], onUpdate: NoAction)

  @@index([organization_id], map: "idx_charges_org_id")
  @@index([status], map: "idx_charges_status")
  @@index([subscription_id], map: "idx_charges_sub_id")
}

model client_approvals {
  id                         String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id            String            @db.Uuid
  client_id                  String            @db.Uuid
  subject_type               String
  subject_id                 String
  document_id                String?           @db.Uuid
  status                     String            @default("PENDING")
  requested_by_type          String?
  requested_by_id            String?
  approved_by_portal_user_id String?           @db.Uuid
  approved_at                DateTime?         @db.Timestamptz(6)
  comment                    String?
  created_at                 DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime?         @default(now()) @db.Timestamptz(6)
  client_clients             client_clients    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  client_documents           client_documents? @relation(fields: [document_id], references: [id], onDelete: Cascade)
  organizations              organizations     @relation(fields: [organization_id], references: [id])

  @@index([client_id], map: "idx_client_approvals_client_id")
  @@index([organization_id], map: "idx_client_approvals_organization_id")
  @@index([status], map: "idx_client_approvals_status")
  @@index([subject_type, subject_id], map: "idx_client_approvals_subject")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model client_clients {
  id                    String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id       String                  @db.Uuid
  full_name             String
  phone                 String?
  email                 String?
  notes                 String?
  metadata              Json?                   @default("{}")
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  client_approvals      client_approvals[]
  organizations         organizations           @relation(fields: [organization_id], references: [id])
  client_document_files client_document_files[]
  client_documents      client_documents[]
  client_feedbacks      client_feedbacks[]
  client_internal_notes client_internal_notes[]
  client_portal_content client_portal_content[]
  client_portal_invites client_portal_invites[]
  client_portal_users   client_portal_users[]
  client_profiles       client_profiles?
  client_service_tiers  client_service_tiers?
  client_sessions       client_sessions[]
  client_shared_files   client_shared_files[]
  client_tasks          client_tasks[]

  @@index([full_name], map: "idx_client_clients_full_name")
  @@index([organization_id, created_at(sort: Desc)], map: "idx_client_clients_org_created_at")
  @@index([organization_id], map: "idx_client_clients_organization_id")
}

model client_dna {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id            String    @unique(map: "idx_client_dna_client_id_unique") @db.Uuid
